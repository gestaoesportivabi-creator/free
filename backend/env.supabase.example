# Referência única para configuração Supabase
# Projeto: jhjrqnggsfeztgkpqcjm (package.json supabase:link)
# Use os MESMOS valores em backend/.env (local) e Vercel (produção)
#
# Obtenha as URLs em: Supabase Dashboard → Settings → Database → Connection string
# Senha com # na URL: codifique como %23

# DATABASE_URL - Transaction pooler (porta 6543) - para queries e serverless
DATABASE_URL=postgresql://postgres.jhjrqnggsfeztgkpqcjm:[SENHA]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require

# DIRECT_URL - Conexão direta (porta 5432) - obrigatório para Prisma migrations
DIRECT_URL=postgresql://postgres:[SENHA]@db.jhjrqnggsfeztgkpqcjm.supabase.co:5432/postgres?sslmode=require

# JWT - OBRIGATÓRIO: mesmo valor em local e Vercel (tokens funcionam em ambos)
JWT_SECRET=sua-chave-secreta-forte
