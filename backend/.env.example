# Database - Supabase (mesmo banco para local e produção)
# Obtenha em: Supabase Dashboard → Settings → Database → Connection string
# DATABASE_URL: use Transaction pooler (porta 6543) - melhor para serverless
# DIRECT_URL: use conexão direta (porta 5432) - obrigatório para Prisma migrations
# Senha: se tiver caracteres especiais, use codificação URL na connection string (ex.: # → %23, @ → %40, : → %3A, / → %2F, ? → %3F, & → %26, = → %3D, % → %25, espaço → %20).
DATABASE_URL=postgresql://postgres.[REF]:[SENHA]@aws-0-[REGIAO].pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require
DIRECT_URL=postgresql://postgres:[SENHA]@db.[REF].supabase.co:5432/postgres?sslmode=require

# Server
PORT=3000
NODE_ENV=development

# JWT - OBRIGATÓRIO: usar o MESMO valor no Vercel para tokens funcionarem em ambos os ambientes
JWT_SECRET=sua-chave-secreta-forte
JWT_EXPIRES_IN=7d

# CORS (local)
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173
