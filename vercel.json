{
  "version": 2,
  "installCommand": "npm install && cd 21Scoutpro && npm install --production=false && cd ../backend && npm install --production=false && rm -rf node_modules/.prisma && npx prisma generate && cd ../api && npm install",
  "buildCommand": "cd backend && rm -rf node_modules/.prisma && npx prisma generate && cd .. && npm run build",
  "outputDirectory": "21Scoutpro/dist",
  "framework": null,
  "env": {
    "PRISMA_SCHEMA_CACHE_BUST": "v6"
  },
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        { "type": "host", "value": "gestaoesportiva-free.vercel.app" }
      ],
      "destination": "https://scout21.vercel.app/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        { "type": "host", "value": "gestaoesportiva-free-scout21s-projects.vercel.app" }
      ],
      "destination": "https://scout21.vercel.app/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
